---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime: number;
}

const { title, description, date, tags, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${title} — Jaskirat Randhawa`} description={description} ogType="article">
  <article class="post">
    <header class="post-header fade-in">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="sep">&middot;</span>
        <span>{readingTime} min read</span>
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
    <nav class="back-link">
      <a href="/blog">&larr; All posts</a>
    </nav>
  </article>
</Base>

<style>
  .post {
    padding: 48px 0;
  }

  .post-header {
    margin-bottom: 40px;
  }

  .post-title {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 8px;
  }

  .post-meta {
    font-size: 14px;
    color: var(--text-muted);
  }

  .sep {
    margin: 0 6px;
  }

  .post-tags {
    margin-top: 12px;
    display: flex;
    gap: 8px;
  }

  .tag {
    font-size: 12px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    padding: 2px 10px;
    border-radius: 12px;
  }

  .back-link {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 14px;
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 24px;
    }
  }
</style>
